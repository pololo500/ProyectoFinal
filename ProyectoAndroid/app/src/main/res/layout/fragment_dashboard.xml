<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:paddingBottom="16dp"
    tools:context=".ui.dashboard.DashboardFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Connection Status Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_connection"
            style="@style/Widget.App.CardView.Colored"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/card_bg_lavender">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/img_teddy_status"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:contentDescription="@string/dashboard_connection_title"
                    android:padding="8dp"
                    app:srcCompat="@drawable/ic_teddy_24dp"
                    app:tint="@color/primary" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dashboard_connection_title"
                        android:textAppearance="@style/TextAppearance.App.CardTitle" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dashboard_connection_subtitle"
                        android:textAppearance="@style/TextAppearance.App.CardSubtitle" />
                </LinearLayout>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_connection_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/dashboard_connection_status_offline"
                    android:textColor="@color/white"
                    app:chipBackgroundColor="@color/card_connection_offline"
                    app:chipMinHeight="28dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Today Summary Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/section_margin_top"
            android:text="@string/dashboard_today_summary"
            android:textAppearance="@style/TextAppearance.App.SectionTitle" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3">

            <!-- Interactions Card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.App.CardView.Colored"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/card_bg_sky">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dashboard_interactions_value"
                        android:textAppearance="@style/TextAppearance.App.MetricValue" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="@string/dashboard_interactions"
                        android:textAppearance="@style/TextAppearance.App.CardSubtitle" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Playtime Card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.App.CardView.Colored"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/card_bg_mint">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dashboard_playtime_value"
                        android:textAppearance="@style/TextAppearance.App.MetricValue" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="@string/dashboard_playtime"
                        android:textAppearance="@style/TextAppearance.App.CardSubtitle" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Mood Card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.App.CardView.Colored"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/card_bg_peach">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dashboard_mood_value"
                        android:textAppearance="@style/TextAppearance.App.MetricValue"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="@string/dashboard_mood"
                        android:textAppearance="@style/TextAppearance.App.CardSubtitle" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Celebrate Achievement Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_celebrate"
            style="@style/Widget.App.CardView.Colored"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/card_bg_rose"
            app:rippleColor="@color/secondary_light">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:contentDescription="@string/dashboard_celebrate_title"
                    android:padding="8dp"
                    app:srcCompat="@drawable/ic_celebrate_24dp"
                    app:tint="@color/card_celebrate" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dashboard_celebrate_title"
                        android:textAppearance="@style/TextAppearance.App.CardTitle"
                        android:textColor="@color/secondary_dark" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dashboard_celebrate_subtitle"
                        android:textAppearance="@style/TextAppearance.App.CardSubtitle" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Recent Alerts -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/section_margin_top"
            android:text="@string/dashboard_alerts_title"
            android:textAppearance="@style/TextAppearance.App.SectionTitle" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.App.CardView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:drawablePadding="12dp"
                    android:gravity="center_vertical"
                    android:padding="12dp"
                    android:text="@string/dashboard_no_alerts"
                    android:textAppearance="@style/TextAppearance.App.CardSubtitle" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
